# === Datenbank ===
# SQLAlchemy-URL. Treiber: psycopg (v3).
DATABASE_URL=postgresql+psycopg://aggregator:aggregator@localhost:5432/aggregator
DB_ECHO=false

# === Sync ===
# Leer = alle registrierten Quellen (aktuell bhg + ahg + sug). Sonst
# kommagetrennt, z.B. "bhg" oder "bhg,ahg,sug".
SYNC_SOURCES=
# Sicherheitsnetz: liefert ein Lauf weniger als dieser Anteil des zuletzt
# aktiven Bestands, wird NICHT deaktiviert (Schutz vor Massen-Fehldeaktivierung).
MIN_FETCH_RATIO=0.5
FETCH_MAX_RETRIES=4
FETCH_RETRY_BACKOFF=2.0

# === Scheduler (nur aggregator.scheduler) ===
# Cron-Ausdruck (UTC). Standard: stündlich zur vollen Stunde.
SCHEDULE_CRON=0 * * * *
RUN_ON_START=true

# === API ===
API_DEFAULT_LIMIT=50
API_MAX_LIMIT=500
# Erlaubte CORS-Ursprünge (kommagetrennt) für Browser-Zugriffe der Webseite.
# Leer = keine Browser-Ursprünge erlaubt. Beispiel:
# CORS_ORIGINS=https://deine-app.lovable.app,https://www.deine-domain.de
CORS_ORIGINS=

# === Logging ===
LOG_LEVEL=INFO
